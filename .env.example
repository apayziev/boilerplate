# ==============================================================================
# Application
# ==============================================================================
APP_NAME="FastAPI Fullstack Boilerplate"
ENVIRONMENT="local" # local, staging, production

# ==============================================================================
# Security / JWT
# ==============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY="your-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SERVER="localhost" # Use "db" for Docker
POSTGRES_PORT=5432
POSTGRES_DB="fastapi"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==============================================================================
# Redis
# ==============================================================================
REDIS_HOST="localhost" # Use "redis" for Docker
REDIS_PORT=6379
ENABLE_REDIS_QUEUE=True
ENABLE_REDIS_RATE_LIMIT=True

# ==============================================================================
# Rate limiting
# ==============================================================================
DEFAULT_RATE_LIMIT_LIMIT=10
DEFAULT_RATE_LIMIT_PERIOD=3600
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_PERIOD=300

# ==============================================================================
# Pagination
# ==============================================================================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# ==============================================================================
# Startup probes (DB / Redis health on lifespan)
# ==============================================================================
STARTUP_RETRY_MAX_ATTEMPTS=5
STARTUP_RETRY_DELAY_SECONDS=2

# ==============================================================================
# Threadpool (AnyIO sync-bridge slots)
# ==============================================================================
THREADPOOL_TOKENS=100

# ==============================================================================
# Reverse-proxy trust
# ==============================================================================
# Comma-separated list of upstream IPs whose X-Forwarded-* headers to trust.
# `*` is permissive — appropriate when Caddy/nginx is the only path to the app.
FORWARDED_ALLOW_IPS=["*"]

# ==============================================================================
# First admin user (created on startup)
# ==============================================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="Change-me"

# ==============================================================================
# CORS (JSON format)
# ==============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ==============================================================================
# Frontend
# ==============================================================================
# Set to /api when running behind a reverse proxy, or a full URL for local dev.
VITE_API_URL="http://localhost:8000"
# Axios request timeout in milliseconds.
VITE_API_TIMEOUT_MS=30000

# ==============================================================================
# Docker (Production)
# ==============================================================================
# Number of Gunicorn workers: (2 * CPU cores) + 1 is typical.
GUNICORN_WORKERS=4

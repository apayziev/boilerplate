# `SITE_ADDRESS` controls the listener and TLS behaviour:
#   - default `:80`           → plain HTTP, suitable for local containers behind another proxy.
#   - `your-domain.com`       → Caddy provisions a Let's Encrypt cert automatically, listens on :443.
#   - `your-domain.com:8443`  → custom port, Caddy still provisions TLS for the host name.
{$SITE_ADDRESS::80} {
	# Security headers
	header {
		X-Frame-Options SAMEORIGIN
		X-Content-Type-Options nosniff
		X-XSS-Protection "1; mode=block"
	}

	# Compression
	encode gzip

	# Backend API routes
	handle /api* {
		reverse_proxy api:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# API documentation routes
	handle /docs* {
		reverse_proxy api:8000
	}

	handle /redoc* {
		reverse_proxy api:8000
	}

	handle /openapi.json {
		reverse_proxy api:8000
	}

	# Prometheus metrics — restrict here when exposing publicly.
	handle /metrics {
		reverse_proxy api:8000
	}

	# Frontend application
	handle {
		reverse_proxy frontend:80 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}
